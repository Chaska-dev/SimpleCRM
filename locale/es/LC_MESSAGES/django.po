msgid "Import Contacts"
msgstr "Importar Contactos"

msgid "Upload a file to import contacts"
msgstr "Sube un archivo para importar contactos"

msgid "File format"
msgstr "Formato de archivo"

msgid "File"
msgstr "Archivo"

msgid "CSV, XLSX, VCF or JSON. Column order doesn't matter — matching is done by header name."
msgstr "CSV, XLSX, VCF o JSON. El orden de columnas no importa — la coincidencia se hace por nombre de encabezado."

msgid "Need a starting point? Download a template:"
msgstr "¿Necesitas un punto de partida? Descarga una plantilla:"

msgid "CSV template"
msgstr "Plantilla CSV"

msgid "Excel template"
msgstr "Plantilla Excel"

msgid "vCard template"
msgstr "Plantilla vCard"

msgid "Export Contacts"
msgstr "Exportar Contactos"

msgid "Download all your contacts"
msgstr "Descarga todos tus contactos"

msgid "Export format"
msgstr "Formato de exportación"

msgid "This will export all"
msgstr "Esto exportará todos"

msgid "contacts from your workspace"
msgstr "contactos de tu espacio de trabajo"

msgid "Column mapping reference"
msgstr "Referencia de mapeo de columnas"

msgid "For CSV and XLSX, the importer matches columns by header name — order does not matter. Synonyms in English and Spanish are accepted."
msgstr "Para CSV y XLSX, el importador hace coincidir las columnas por nombre de encabezado — el orden no importa. Se aceptan sinónimos en inglés y español."

msgid "Field"
msgstr "Campo"

msgid "Accepted header names (EN + ES)"
msgstr "Nombres de encabezado aceptados (EN + ES)"

msgid "Notes"
msgstr "Notas"

msgid "Supported formats"
msgstr "Formatos soportados"

msgid "Comma-separated values. The safest choice — every spreadsheet app can read it."
msgstr "Valores separados por comas. La opción más segura — todas las hojas de cálculo pueden leerlo."

msgid "Microsoft Excel. The first row must contain the column headers."
msgstr "Microsoft Excel. La primera fila debe contener los encabezados de columna."

msgid "Standard contact format. Compatible with macOS Contacts, Google Contacts, Outlook, iOS and Android."
msgstr "Formato estándar de contactos. Compatible con macOS Contacts, Google Contacts, Outlook, iOS y Android."

msgid "List of contact objects. Useful for developers and migrations from other systems."
msgstr "Lista de objetos de contacto. Útil para desarrolladores y migraciones desde otros sistemas."

msgid "For"
msgstr "Para"

msgid "the standard vCard 3.0 properties are used"
msgstr "se usan las propiedades estándar de vCard 3.0"

msgid "use the same field names as in the CSV headers (camelCase is also accepted)"
msgstr "usa los mismos nombres de campo que en los encabezados CSV (camelCase también es aceptado)"

#: templates/contacts/list.html
msgid "Visible Columns"
msgstr "Columnas Visibles"

#: Field descriptions from import_export.py
msgid "Required. Given / first name."
msgstr "Requerido. Nombre de pila."

msgid "Optional. Middle name."
msgstr "Opcional. Segundo nombre."

msgid "Optional. Family / last name."
msgstr "Opcional. Apellido."

msgid "Optional. Informal name."
msgstr "Opcional. Nombre informal."

msgid "Optional. MALE / FEMALE / OTHER / PREFER_NOT_TO_SAY."
msgstr "Opcional. MASCULINO / FEMENINO / OTRO / PREFIERO_NO_DECIR."

msgid "Optional. YYYY-MM-DD."
msgstr "Opcional. AAAA-MM-DD."

msgid "Optional. Personal email address."
msgstr "Opcional. Correo personal."

msgid "Optional. Work / business email address."
msgstr "Opcional. Correo de trabajo."

msgid "Optional. Mobile / cell phone."
msgstr "Opcional. Teléfono móvil."

msgid "Optional. Office phone or extension."
msgstr "Opcional. Teléfono de oficina o extensión."

msgid "Optional. Company name. Created if it does not exist."
msgstr "Opcional. Nombre de empresa. Se crea si no existe."

msgid "Optional. Personal website URL."
msgstr "Opcional. URL de sitio web personal."

msgid "Optional. Postal address (free text)."
msgstr "Opcional. Dirección postal (texto libre)."

msgid "Optional. Country name (Spanish or English)."
msgstr "Opcional. Nombre de país (español o inglés)."

msgid "Optional. State / province name."
msgstr "Opcional. Nombre de estado / provincia."

msgid "Optional. City name."
msgstr "Opcional. Nombre de ciudad."

msgid "Optional. Free-form notes."
msgstr "Opcional. Notas de texto libre."

msgid "Optional. Full LinkedIn profile URL."
msgstr "Opcional. URL completa del perfil de LinkedIn."

msgid "Optional. Full GitHub profile URL."
msgstr "Opcional. URL completa del perfil de GitHub."

msgid "Optional. Full Facebook profile URL."
msgstr "Opcional. URL completa del perfil de Facebook."

msgid "Optional. Full Instagram profile URL."
msgstr "Opcional. URL completa del perfil de Instagram."

msgid "Optional. Full Twitter / X profile URL."
msgstr "Opcional. URL completa del perfil de Twitter / X."

msgid "Optional. Full TikTok profile URL."
msgstr "Opcional. URL completa del perfil de TikTok."

msgid "Optional. Full YouTube channel URL."
msgstr "Opcional. URL completa del canal de YouTube."

msgid "Optional. Full Telegram URL or @handle."
msgstr "Opcional. URL completa de Telegram o @usuario."

msgid "Optional. Discord username."
msgstr "Opcional. Nombre de usuario de Discord."

