# Django
SECRET_KEY=CHANGE-ME-please-generate-a-new-one-with-django
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite)
# Leave empty to use SQLite. Example for Postgres:
# DATABASE_URL=postgres://crm:crm@db:5432/crm
DATABASE_URL=

# CORS / Trusted origins (comma separated, optional)
CSRF_TRUSTED_ORIGINS=

# Cookies are secure only when not in DEBUG
# Set to "True" only if you are behind HTTPS in production
SECURE_COOKIES=True
